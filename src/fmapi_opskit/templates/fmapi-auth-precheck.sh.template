#!/bin/sh
set -eu

FMAPI_PROFILE="__PROFILE__"
FMAPI_HOST="__HOST__"

# Run Databricks CLI without env-based auth overrides (use profile-based OAuth only)
_dbx() {
  env \
    -u DATABRICKS_TOKEN \
    -u DATABRICKS_HOST \
    -u DATABRICKS_AUTH_TYPE \
    -u DATABRICKS_CLIENT_ID \
    -u DATABRICKS_CLIENT_SECRET \
    databricks "$@"
}

# Read hook event name from stdin JSON (Claude Code passes context via stdin)
HOOK_EVENT_NAME="unknown"
if [ ! -t 0 ]; then
  _stdin=$(cat)
  HOOK_EVENT_NAME=$(printf '%s' "$_stdin" | jq -r '.hook_event_name // "unknown"' 2>/dev/null) || HOOK_EVENT_NAME="unknown"
fi

# Refresh early when token has <5 minutes remaining to reduce 403s in long sessions
_EXPIRY_BUFFER_SECONDS=300

_fetch_token_json() {
  _dbx auth token --profile "$FMAPI_PROFILE" --output json 2>/dev/null || true
}

_get_expires_in_seconds() {
  printf '%s' "$1" | jq -r '
    (
      .expires_in // .expiresIn //
      (
        (.expiry // .expires_at // .expiresAt // empty)
        | (fromdateiso8601? - now)
      )
    )
    | tonumber?
    | if . == null then empty else floor end
  ' 2>/dev/null || true
}

_is_expiring_soon() {
  _exp_in="$1"
  if [ -z "$_exp_in" ]; then
    return 1
  fi
  case "$_exp_in" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$_exp_in" -le "$_EXPIRY_BUFFER_SECONDS" ] 2>/dev/null
}

# Happy path: token is valid and not near expiry
_token_json=$(_fetch_token_json)
if [ -n "$_token_json" ]; then
  _exp_in=$(_get_expires_in_seconds "$_token_json")
  if ! _is_expiring_soon "$_exp_in"; then
    exit 0
  fi

  # Near-expiry path: fetch once more so Databricks CLI can refresh if available
  _token_json=$(_fetch_token_json)
  _exp_in=$(_get_expires_in_seconds "$_token_json")
  if ! _is_expiring_soon "$_exp_in"; then
    printf '{"hookSpecificOutput":{"hookEventName":"%s","additionalContext":"FMAPI: OAuth token was near expiry and has been refreshed."}}\n' "$HOOK_EVENT_NAME"
    exit 0
  fi
fi

# Token expired — attempt refresh

# Detect headless environments (SSH without display forwarding)
_is_headless() {
  # WSL can open a browser via Windows interop
  [ -n "${WSL_DISTRO_NAME:-}" ] && return 1
  [ -f /proc/version ] && grep -qi 'microsoft' /proc/version 2>/dev/null && return 1
  [ -n "${SSH_CONNECTION:-}" ] && [ -z "${DISPLAY:-}" ] && return 0
  [ -n "${SSH_TTY:-}" ] && [ -z "${DISPLAY:-}" ] && return 0
  [ ! -e /dev/tty ] && return 0
  return 1
}

if _is_headless; then
  # Can't re-auth in headless — warn but don't block
  printf '{"hookSpecificOutput":{"hookEventName":"%s","additionalContext":"FMAPI: OAuth token may be expired. If you encounter auth errors, re-authenticate with: /fmapi-codingagent-reauth"}}\n' "$HOOK_EVENT_NAME"
  exit 0
fi

# Attempt browser-based re-auth with timeout
_reauth_ok=false
if command -v timeout >/dev/null 2>&1; then
  env -u DATABRICKS_TOKEN -u DATABRICKS_HOST -u DATABRICKS_AUTH_TYPE -u DATABRICKS_CLIENT_ID -u DATABRICKS_CLIENT_SECRET timeout 30 databricks auth login --host "$FMAPI_HOST" --profile "$FMAPI_PROFILE" >/dev/null 2>&1 && _reauth_ok=true
else
  _dbx auth login --host "$FMAPI_HOST" --profile "$FMAPI_PROFILE" >/dev/null 2>&1 && _reauth_ok=true
fi

if [ "$_reauth_ok" = true ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"%s","additionalContext":"FMAPI: OAuth token was expired and has been refreshed."}}\n' "$HOOK_EVENT_NAME"
else
  printf '{"hookSpecificOutput":{"hookEventName":"%s","additionalContext":"FMAPI: OAuth token may be expired and could not be refreshed. If you encounter auth errors, re-authenticate with: /fmapi-codingagent-reauth"}}\n' "$HOOK_EVENT_NAME"
fi

exit 0
