#!/bin/sh
set -eu

FMAPI_PROFILE="__PROFILE__"
FMAPI_HOST="__HOST__"

# Verify required commands exist
for _cmd in databricks jq; do
  if ! command -v "$_cmd" >/dev/null 2>&1; then
    echo "FMAPI: $_cmd not found. Install it and ensure it is on your PATH." >&2
    exit 1
  fi
done

_EXPIRY_BUFFER_SECONDS=300
_REAUTH_TIMEOUT_SECONDS=180
_REAUTH_POLL_INTERVAL_SECONDS=1
_DBX_CACHE_LOCK_WAIT_SECONDS=10
_DBX_TOKEN_CACHE="$HOME/.databricks/token-cache.json"
_DBX_CACHE_LOCK="$HOME/.databricks/.fmapi-token-cache-expire-lock"

# Run Databricks CLI without env-based auth overrides (profile-based OAuth only)
_dbx() {
  env \
    -u DATABRICKS_TOKEN \
    -u DATABRICKS_HOST \
    -u DATABRICKS_AUTH_TYPE \
    -u DATABRICKS_CLIENT_ID \
    -u DATABRICKS_CLIENT_SECRET \
    databricks "$@"
}

_get_access_token() {
  printf '%s' "$1" | jq -r '.access_token // empty' 2>/dev/null || true
}

# Extract the 'exp' claim (epoch seconds) from a JWT access token embedded
# in the CLI response. Uses jq for base64url decoding for portability.
_get_jwt_exp() {
  printf '%s' "$1" | jq -r '
    .access_token // empty
    | split(".")[1]? // empty
    | gsub("-"; "+") | gsub("_"; "/")
    | . + (
        if (length % 4) == 2 then "=="
        elif (length % 4) == 3 then "="
        else "" end
      )
    | @base64d | fromjson? | .exp // empty | tonumber?
  ' 2>/dev/null || true
}

# Get seconds remaining until a token expires.
# Tries the CLI-provided expires_in field first, then JWT exp fallback.
_get_token_time_left() {
  _ttl_json="$1"

  _ttl_ei=$(printf '%s' "$_ttl_json" | jq -r '.expires_in // .expiresIn // empty' 2>/dev/null) || true
  if [ -n "$_ttl_ei" ]; then
    printf '%s' "$_ttl_ei"
    return 0
  fi

  _ttl_exp=$(_get_jwt_exp "$_ttl_json")
  if [ -n "$_ttl_exp" ]; then
    _ttl_now=$(date +%s)
    printf '%s' "$(( _ttl_exp - _ttl_now ))"
    return 0
  fi
}

_is_expiring_soon() {
  _exp_in="$1"
  [ -z "$_exp_in" ] && return 1
  case "$_exp_in" in
    *[!0-9-]*) return 1 ;;
  esac
  [ "$_exp_in" -le "$_EXPIRY_BUFFER_SECONDS" ] 2>/dev/null
}

_clear_databricks_token_cache() {
  rm -f "$_DBX_TOKEN_CACHE" 2>/dev/null || true
}

_acquire_dbx_cache_lock() {
  mkdir -p "$HOME/.databricks" 2>/dev/null || true

  _waited=0
  while [ "$_waited" -lt "$_DBX_CACHE_LOCK_WAIT_SECONDS" ]; do
    if mkdir "$_DBX_CACHE_LOCK" 2>/dev/null; then
      return 0
    fi
    sleep 1
    _waited=$(( _waited + 1 ))
  done

  return 1
}

_release_dbx_cache_lock() {
  rm -rf "$_DBX_CACHE_LOCK" 2>/dev/null || true
}

_expire_databricks_token_cache_unlocked() {
  [ -f "$_DBX_TOKEN_CACHE" ] || return 0

  _past=$(date -u -d "1 hour ago" +"%Y-%m-%dT%H:%M:%S.000000000Z" 2>/dev/null \
       || date -u -v-1H +"%Y-%m-%dT%H:%M:%S.000000000Z" 2>/dev/null \
       || echo "2000-01-01T00:00:00.000000000Z")

  _updated=$(jq --arg past "$_past" '
    if .Tokens then .Tokens |= map_values(.expiry = $past)
    elif .tokens then .tokens |= map_values(.expiry = $past)
    else . end
  ' "$_DBX_TOKEN_CACHE" 2>/dev/null) || {
    _clear_databricks_token_cache
    return 0
  }

  [ -n "$_updated" ] || {
    _clear_databricks_token_cache
    return 0
  }

  _tmp="${_DBX_TOKEN_CACHE}.$$"
  printf '%s\n' "$_updated" > "$_tmp" 2>/dev/null || {
    rm -f "$_tmp" 2>/dev/null || true
    _clear_databricks_token_cache
    return 0
  }
  chmod 600 "$_tmp" 2>/dev/null || true
  mv -f "$_tmp" "$_DBX_TOKEN_CACHE" 2>/dev/null || {
    rm -f "$_tmp" 2>/dev/null || true
    _clear_databricks_token_cache
    return 0
  }
}

_force_refresh_databricks_token_cache() {
  if _acquire_dbx_cache_lock; then
    _expire_databricks_token_cache_unlocked
    _release_dbx_cache_lock
  fi
  return 0
}

_fetch_token() {
  _token_json=$(_dbx auth token --profile "$FMAPI_PROFILE" --output json 2>/dev/null || true)
  _token=$(_get_access_token "$_token_json")
  [ -n "$_token" ] || return 1

  _expires_in=$(_get_token_time_left "$_token_json")
  if _is_expiring_soon "$_expires_in"; then
    _force_refresh_databricks_token_cache

    _token_json=$(_dbx auth token --profile "$FMAPI_PROFILE" --output json 2>/dev/null || true)
    _token=$(_get_access_token "$_token_json")
    [ -n "$_token" ] || return 1

    _expires_in=$(_get_token_time_left "$_token_json")
    _is_expiring_soon "$_expires_in" && return 1
  fi

  printf '%s' "$_token"
}

_stop_login_process() {
  _pid="$1"
  if ! kill -0 "$_pid" 2>/dev/null; then
    wait "$_pid" 2>/dev/null || true
    return 0
  fi

  kill "$_pid" 2>/dev/null || true
  if kill -0 "$_pid" 2>/dev/null; then
    kill -9 "$_pid" 2>/dev/null || true
  fi
  wait "$_pid" 2>/dev/null || true
}

_auto_reauth_and_emit_token() {
  echo "FMAPI: OAuth session expired. Attempting automatic re-authentication ..." >&2

  env -u DATABRICKS_TOKEN -u DATABRICKS_HOST -u DATABRICKS_AUTH_TYPE \
    -u DATABRICKS_CLIENT_ID -u DATABRICKS_CLIENT_SECRET \
    databricks auth login --host "$FMAPI_HOST" --profile "$FMAPI_PROFILE" 1>&2 &
  _login_pid=$!

  _start_epoch=$(date +%s)
  while :; do
    token=$(_fetch_token || true)
    if [ -n "$token" ]; then
      _stop_login_process "$_login_pid"
      echo "$token"
      return 0
    fi

    if ! kill -0 "$_login_pid" 2>/dev/null; then
      wait "$_login_pid" 2>/dev/null || true
      token=$(_fetch_token || true)
      if [ -n "$token" ]; then
        echo "$token"
        return 0
      fi
      return 1
    fi

    _now_epoch=$(date +%s)
    [ $(( _now_epoch - _start_epoch )) -ge "$_REAUTH_TIMEOUT_SECONDS" ] && break
    sleep "$_REAUTH_POLL_INTERVAL_SECONDS"
  done

  _stop_login_process "$_login_pid"
  return 1
}

# 1) Fast path: fetch token (with silent refresh if near expiry)
token=$(_fetch_token || true)
if [ -n "$token" ]; then
  echo "$token"
  exit 0
fi

# 2) Auto re-auth fallback (all environments)
if _auto_reauth_and_emit_token; then
  exit 0
fi

# 3) Last cache recovery attempt, then manual guidance
_clear_databricks_token_cache
token=$(_fetch_token || true)
if [ -n "$token" ]; then
  echo "$token"
  exit 0
fi

echo "FMAPI: OAuth session expired. Re-authenticate manually:" >&2
echo "FMAPI:   databricks auth login --host $FMAPI_HOST --profile $FMAPI_PROFILE" >&2
echo "FMAPI: In Claude Code, run /fmapi-codingagent-reauth" >&2
exit 1
